{
  "version": 2,
  "builds": [
    { "src": "src/server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/uv/(.*)", "dest": "/public/uv/$1" },
    { "src": "/baremux/(.*)", "dest": "/public/baremux/$1" },
    { "src": "/(.*)", "dest": "/src/server.js" }
  ]
}
